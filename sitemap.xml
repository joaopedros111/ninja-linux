---
layout: null
permalink: /sitemap.xml
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {% assign hostname = site.url | append: site.baseurl %}
  {% for page in site.pages %}
    {% if page.url contains '.xml' or page.url contains '.txt' or page.url contains '.json' or page.url contains '.pdf' %}
      {% continue %}
    {% endif %}
    {% if page.url == '/404.html' %}
      {% continue %}
    {% endif %}
    <url>
      <loc>{{ hostname }}{{ page.url | replace: 'index.html', '' }}</loc>
      <lastmod>{{ page.last_modified_at | default: page.date | default: site.time | date: '%Y-%m-%d' }}</lastmod>
      <changefreq>monthly</changefreq>
    </url>
  {% endfor %}
</urlset>
